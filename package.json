{
  "name": "sprite-lite",
  "version": "0.1.1",
  "description": "Zero-dependency 8×8 pixel-art animation component for React.",
  "keywords": ["react", "animation", "pixel-art", "sprite", "component", "svg", "ui", "zero-dependency"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/marcsist/sprite-light.git"
  },
  "homepage": "https://github.com/marcsist/sprite-light#readme",
  "bugs": {
    "url": "https://github.com/marcsist/sprite-light/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.0"
  },
  "license": "MIT"
}
